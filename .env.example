# =============================================================================
#  AI ScrumBot — environment configuration
#  Copy to `.env` and fill in. Every variable maps 1:1 to scrumbot/config.py.
# =============================================================================

## --- LLM ---------------------------------------------------------------------
# Supported: OpenAI ("gpt-4o"), Anthropic ("claude-3-5-sonnet-latest"),
# Gemini ("gemini-1.5-pro"), NVIDIA NIM ("meta/llama-3.1-70b-instruct"),
# Ollama ("ollama/llama3").
SCRUM_AGENT_MODEL="gemini-1.5-pro"
SCRUM_AGENT_TEMPERATURE=0

## Provider keys (provide the one(s) matching your model)
OPENAI_API_KEY=your_openai_key
ANTHROPIC_API_KEY=your_anthropic_key
GOOGLE_API_KEY=your_gemini_key
NVIDIA_API_KEY=your_nvidia_nim_key
# OLLAMA_BASE_URL="http://localhost:11434"

## --- Discord -----------------------------------------------------------------
DISCORD_TOKEN=your_discord_bot_token
# Channel the scheduled daily standup posts to (numeric id). Unset = disabled.
# STANDUP_CHANNEL_ID=123456789012345678

## --- DevOps backend (primary integration) ------------------------------------
DEVOPS_API_URL="https://api.your-company.com/api"
BOT_API_KEY="your_bot_api_key_here"
# DEVOPS_TIMEOUT_SECONDS=15
# DEVOPS_MAX_RETRIES=3
# DEVOPS_MAX_CONNECTIONS=20

## --- Vector store / embeddings -----------------------------------------------
CHROMA_DB_PATH="resources/chroma"
CHROMA_COLLECTION="discord_chat_data"
# "fastembed" = local ONNX model, no API key required (default).
# "openai"    = hosted embeddings (requires OPENAI_API_KEY).
EMBEDDING_PROVIDER="fastembed"
EMBEDDING_MODEL="BAAI/bge-small-en-v1.5"

## --- Agent memory ------------------------------------------------------------
# Leave unset to use an in-process MemorySaver checkpointer.
# MONGO_DB_URL="mongodb://localhost:27017/"

## --- Async work queue --------------------------------------------------------
# QUEUE_WORKERS=3

## --- MCP server --------------------------------------------------------------
# Transport used when running `python main.py --mode mcp`.
# stdio for local tool clients; http/sse to run alongside the Discord bot.
MCP_TRANSPORT="stdio"
# MCP_HOST="127.0.0.1"
# MCP_PORT=8765

## --- Webhook receiver (DevOps -> Discord) ------------------------------------
# Set a secret to enable the receiver in `--mode both`. The DevOps backend must
# send it in the `X-Webhook-Secret` header. Events are announced in NOTIFY_CHANNEL_ID.
# WEBHOOK_SECRET="a-long-random-string"
# WEBHOOK_HOST="0.0.0.0"
# WEBHOOK_PORT=8080
# NOTIFY_CHANNEL_ID=123456789012345678

## --- Observability -----------------------------------------------------------
LOG_LEVEL="INFO"
