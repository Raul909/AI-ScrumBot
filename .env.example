## LLM Configuration
# Supported: OpenAI ("gpt-4o"), Anthropic ("claude-3-opus-20240229"), Gemini ("gemini-1.5-pro"), NVIDIA ("meta/llama-3.1-70b-instruct"), Ollama ("llama3")
SCRUM_AGENT_MODEL="gemini-1.5-pro"
SCRUM_AGENT_TEMPERATURE=0

## Provider Keys (provide at least one)
OPENAI_API_KEY=your_openai_key
ANTHROPIC_API_KEY=your_anthropic_key
GOOGLE_API_KEY=your_gemini_key
NVIDIA_API_KEY=your_nvidia_nim_key

## Discord Configuration
DISCORD_TOKEN=your_discord_bot_token

## DevOpsBackend Integration (Primary Backend)
DEVOPS_API_URL="https://api.your-company.com/api"
BOT_API_KEY="your_bot_api_key_here"

## Taiga Configuration (Optional)
# Uncomment and configure if you still want to use Taiga as a secondary MCP tool
# TAIGA_API_URL="https://api.taiga.io"
# TAIGA_TOKEN="your_taiga_token"

## Chroma Database
CHROMA_DB_PATH="resources/chroma"
CHROMA_DB_DISCORD_CHAT_DATA_NAME="discord_chat_data"

## MongoDB (Optional - if empty, in-memory sqlite is used)
# MONGO_DB_URL="mongodb://localhost:27017/"
